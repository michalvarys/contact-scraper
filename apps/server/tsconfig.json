{
  "extends": "@contact-scraper/config-typescript/node.json",
  "compilerOptions": {
    "rootDir": "src",
    "module": "Node16",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "moduleResolution":"nodenext",
    "allowSyntheticDefaultImports": true,
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
