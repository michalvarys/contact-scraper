{
  "name": "contact-scraper",
  "version": "1.0.0",
  "description": "A web scraper for Google Maps using Puppeteer",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "prisma": {
    "schema": "packages/db/prisma/schema.prisma",
    "seed": "tsx packages/db/src/seed.ts"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "clean": "turbo run clean",
    "start": "turbo run start --parallel"
  },
  "keywords": [
    "google-maps",
    "scraper",
    "puppeteer",
    "automation"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@9.14.2",
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "axios": "^1.8.2",
    "cheerio": "^1.0.0",
    "puppeteer": "^24.0.0",
    "xml2js": "^0.6.2",
    "locate-chrome": "^0.1.1"
  },
  "pnpm": {
    "overrides": {
      "h3": ">=1.15.6",
      "jws": ">=3.2.3",
      "form-data": ">=4.0.4",
      "tar-fs": ">=3.0.8",
      "basic-ftp": ">=5.2.0",
      "defu": ">=6.1.5",
      "flatted": ">=3.4.0",
      "rollup": ">=4.59.0",
      "undici": "~6.26.0",
      "ws": ">=8.17.1",
      "picomatch": ">=4.0.4",
      "path-to-regexp": "0.1.13",
      "@trpc/server": ">=10.45.3",
      "minimatch": ">=9.0.7",
      "tar": ">=7.5.7",
      "glob@>=10": ">=10.5.0",
      "lodash": ">=4.18.0",
      "@babel/helpers": ">=7.26.10",
      "@babel/runtime": ">=7.26.10",
      "@hono/node-server": ">=1.19.13",
      "postcss": ">=8.5.10",
      "yaml": ">=2.8.3",
      "ip-address": ">=10.1.1",
      "js-yaml": ">=4.1.1",
      "ajv": ">=6.14.0",
      "qs": ">=6.15.2",
      "diff": ">=4.0.4",
      "@eslint/plugin-kit": ">=0.3.4",
      "@tootallnate/once": ">=2.0.1"
    }
  },
  "devDependencies": {
    "@types/node": "^20.5.0",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "concurrently": "^9.1.2",
    "eslint": "^8.47.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "turbo": "latest",
    "typescript": "^5.1.6"
  }
}
