{
    "name": "@contact-scraper/types",
    "version": "0.1.0",
    "private": true,
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts",
        "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
        "clean": "rm -rf dist",
        "lint": "eslint src/**/*.ts",
        "type-check": "tsc --noEmit"
    },
    "devDependencies": {
        "@contact-scraper/config-eslint": "workspace:*",
        "@contact-scraper/config-typescript": "workspace:*",
        "eslint": "^9.0.0",
        "tsup": "^8.0.2",
        "typescript": "^5.4.2"
    }
}