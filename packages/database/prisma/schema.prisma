// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgres"
  url      = env("DATABASE_PG_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id            String           @id @default(uuid())
  name          String
  address       String
  email         String?
  phone         String?
  website       String?
  categories    Category[]
  link          String           @unique
  reviewsCount  Int              @default(0)
  scrapedAt     DateTime
  metadata      CompanyMetadata?
  metadataId    String?
  odooMailingContactId Int? // Odoo mailing.contact ID when synced
  odooPartnerId        Int? // Odoo res.partner ID when synced
  icpScores     IcpCompanyScore[]
}

model CompanyMetadata {
  id        String          @id @default(uuid())
  notes     String?
  // JSON
  data      String?
  website   CompanyWebsite?
  company   Company         @relation(fields: [companyId], references: [id])
  companyId String          @unique
}

model CompanyWebsite {
  id        String  @id @default(uuid())
  link      String
  thumbnail String?
  // JSON
  data      String?

  CompanyMetadata CompanyMetadata @relation(fields: [metadataId], references: [id])
  metadataId      String          @unique
}

model Category {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  companies   Company[]
  icpProfiles IcpProfile[]
}

// ICP (Ideal Customer Profile)
model IcpProfile {
  id              String         @id @default(uuid())
  name            String
  description     String         // User's brief ICP description
  enrichedData    String?        // AI-enriched JSON: detailed criteria, keywords, industries
  searchQueries   String?        // AI-generated JSON array of search queries for scrapers
  scoreThreshold  Int            @default(60) // Minimum score (0-100) to keep a lead
  categoryId      Int?           // Auto-created category for tagging matching leads
  category        Category?      @relation(fields: [categoryId], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  scraperTasks    ScraperTask[]
  companyScores   IcpCompanyScore[]
}

model IcpCompanyScore {
  id          String     @id @default(uuid())
  score       Int        // 0-100 match score
  reasoning   String?    // AI reasoning for the score
  companyId   String
  company     Company    @relation(fields: [companyId], references: [id])
  icpId       String
  icp         IcpProfile @relation(fields: [icpId], references: [id])
  scoredAt    DateTime   @default(now())

  @@unique([companyId, icpId])
}

// Modely pro scraper queue
model ScraperTask {
  id            String            @id @default(uuid())
  status        ScraperTaskStatus @default(PENDING)
  scraperType   String // Typ scraperu (např. "GoogleMapsScraper", "FirmyCzScraper")
  scraperConfig String // JSON konfigurace scraperu (parametry pro inicializaci)
  searchQuery   String? // Vyhledávací dotaz, pokud je použit
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  startedAt     DateTime? // Kdy byl task spuštěn
  completedAt   DateTime? // Kdy byl task dokončen
  errorMessage  String? // Chybová hláška v případě selhání
  scrapedLinks  ScrapedLink[] // Odkazy, které scraper nalezl a zpracoval
  logs          ScraperTaskLog[] // Logy k tasku
  icpProfileId  String?
  icpProfile    IcpProfile?       @relation(fields: [icpProfileId], references: [id])
}

enum ScraperTaskStatus {
  PENDING // Čeká na zpracování
  RUNNING // Právě běží
  COMPLETED // Úspěšně dokončen
  FAILED // Selhal s chybou
  PROCESSED
  PAUSED // Pozastaven (např. manuálně)
  INTERRUPTED // Přerušen nečekaným ukončením serveru
}

model ScrapedLink {
  id           String            @id @default(uuid())
  link         String // URL odkazu
  status       ScrapedLinkStatus @default(PENDING)
  processedAt  DateTime? // Kdy byl odkaz zpracován
  errorMessage String? // Chybová hláška v případě selhání
  companyId    String? // ID společnosti (pokud byla uložena)
  task         ScraperTask       @relation(fields: [taskId], references: [id])
  taskId       String // Odkaz na task, který tento odkaz zpracovává
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

enum ScrapedLinkStatus {
  PENDING // Čeká na zpracování
  RUNNING // Právě běží
  PROCESSED // Úspěšně zpracován
  FAILED // Selhal s chybou
  SKIPPED // Přeskočen (např. už existuje v databázi)
}

model ScraperTaskLog {
  id        String      @id @default(uuid())
  message   String // Zpráva logu
  level     LogLevel    @default(INFO)
  task      ScraperTask @relation(fields: [taskId], references: [id])
  taskId    String // Odkaz na task
  createdAt DateTime    @default(now())
}

enum LogLevel {
  DEBUG
  INFO
  WARNING
  ERROR
}
