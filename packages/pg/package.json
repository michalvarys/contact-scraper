{
    "name": "@contact-scraper/pg",
    "version": "0.0.0",
    "scripts": {
        "pg:generate": "prisma generate && npx prisma generate --schema=prisma/schema.pg.prisma",
        "pg:migrate": "prisma migrate dev --skip-generate --schema=prisma/schema.pg.prisma",
        "pg:deploy": "prisma migrate deploy --schema=prisma/schema.pg.prisma",
        "pg:sync": "tsx migration/index.ts"
    },
    "exports": {
        ".": "./src/index.ts"
    },
    "devDependencies": {
        "@contact-scraper/config-eslint": "workspace:*",
        "@contact-scraper/config-typescript": "workspace:*",
        "prisma": "^6.4.1",
        "tsx": "^4.7.0",
        "typescript": "^5.3.3"
    },
    "dependencies": {
        "@prisma/client": "^6.4.1"
    }
}