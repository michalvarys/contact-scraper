# ===========================================
# Contact Scraper - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Database ---
DATABASE_PG_URL="postgresql://postgres:Scraper123@localhost:5432/postgres"

# --- Google Gemini (for contact enrichment) ---
GEMINI_API_KEY=your-gemini-api-key

# --- Storage ---
STORAGE_BASE_DIR=./apps/storage-data
STORAGE_PUBLIC_URL=/storage

# --- Ports ---
SERVER_PORT=30020
CLIENT_PORT=30010

# --- Client ---
NEXT_PUBLIC_API_URL=http://localhost:30020
NEXT_PUBLIC_STORAGE_URL=/storage
NODE_ENV=development

# --- Odoo CRM Integration (optional) ---
ODOO_URL=http://localhost:8069
ODOO_DB=odoo
ODOO_USERNAME=admin
ODOO_PASSWORD=admin

# --- Puppeteer / Browser (optional, for Docker) ---
# BROWSER_WS_ENDPOINT=ws://localhost:30033?token=puppeteer123
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# --- Auth ---
# JWT_SECRET=change-me-in-production
